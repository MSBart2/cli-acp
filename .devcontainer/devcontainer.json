{
  "name": "ACP Agent Orchestrator",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",

  "features": {
    // Adds git, gh CLI, and common utilities to the base Node image
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Install system libraries required by Playwright's Chromium headless shell,
  // then install all Node dependencies and Playwright browsers.
  "postCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y xvfb libnspr4 libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 && cd webapp && npm run install:all && npm install --save-dev @playwright/test && npx playwright install chromium",

  // Forward the Express server, Vite dev server, and Playwright UI ports
  "forwardPorts": [3001, 5173, 9323],
  "portsAttributes": {
    "3001": {
      "label": "Express server",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vite dev server",
      "onAutoForward": "openBrowser"
    },
    "9323": {
      "label": "Playwright UI",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "vitejs.vite"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Mount a Docker socket so the container can run git clone / child processes
  "mounts": [],

  "remoteEnv": {
    // Point to the gh-installed Copilot CLI extension; override if using a
    // custom binary path inside the container.
    "COPILOT_CLI_PATH": "copilot",
    "PORT": "3001"
  },

  "remoteUser": "node"
}
