# Enforce LF line endings in the repo for all text files.
# Without this, Windows git clients will convert to CRLF on checkout,
# producing spurious diffs across every file.
* text=auto eol=lf

# Explicitly mark common text formats
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sh   text eol=lf

# Binary files — never convert
*.png  binary
*.jpg  binary
*.gif  binary
*.webp binary
*.ico  binary
# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union
