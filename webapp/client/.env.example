# ACP Agent Orchestrator — Client environment variables
#
# Copy this file to .env and set values for your local machine.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
#
# All variables are optional — sane defaults are used when unset.

# Default base directory for cloning repositories.
# Leave empty to use the server's default (/tmp/acp-repos on Linux,
# %TEMP%\acp-repos on Windows).  Set an absolute path to use a custom
# location, e.g. your local source tree:
#
#   Windows: VITE_REPO_BASE_DIR=C:\users\yourname\source
#   macOS:   VITE_REPO_BASE_DIR=/Users/yourname/source
#   Linux:   VITE_REPO_BASE_DIR=/home/yourname/source
#
VITE_REPO_BASE_DIR=
