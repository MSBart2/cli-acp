# ACP Agent Orchestrator — Server environment variables
#
# Copy this file to .env and set values for your local machine.
#
# All variables are optional — sane defaults are used when unset.

# Port the Express + Socket.IO server listens on.
# PORT=3001

# Absolute path to the GitHub Copilot CLI binary.
# Defaults to "copilot" (resolved via PATH).
# COPILOT_CLI_PATH=copilot

# Base directory for shallow-cloned repositories.
# Defaults to <os.tmpdir()>/acp-repos.
#
#   Windows: REPO_BASE_DIR=C:\users\yourname\source
#   macOS:   REPO_BASE_DIR=/Users/yourname/source
#   Linux:   REPO_BASE_DIR=/home/yourname/source
#
# REPO_BASE_DIR=
