# Express server port
PORT=3001

# Path to the GitHub Copilot CLI binary
COPILOT_CLI_PATH=copilot

# Base directory for cloned repositories
REPO_BASE_DIR=

# Optional override for saved session snapshots
ACP_SESSION_DIR=

# Optional server log level if structured logging is enabled
LOG_LEVEL=info

# Optional: auto-launch these repos when the browser first connects.
# Leave blank to disable auto-launch.
# Comma-separated list for workers (spaces around commas are ignored).
DEFAULT_ORCHESTRATOR_URL=
DEFAULT_WORKER_URLS=
# Optional: model to use for all auto-launched agents (leave blank for CLI default).
DEFAULT_MODEL=
